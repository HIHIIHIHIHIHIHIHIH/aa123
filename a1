--[[
    Tiny Remote Spammer using Mercury UI Library
    - Dropdown to select one remote
    - Toggle "Spam All" to spam all remotes
    - Compact & draggable
]]

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/deeeity/mercury-lib/master/src.lua"))()

-- Create a tiny window
local gui = Library:create{
    Theme = Library.Themes.Dark,  -- Use Dark theme for compactness
    Size = UDim2.new(0, 280, 0, 200) -- Small size
}

-- ======== SCAN _NETMANAGED ========
local function getNetManaged()
    local path = game:GetService("ReplicatedStorage"):FindFirstChild("rbxts_include")
        and game:GetService("ReplicatedStorage").rbxts_include:FindFirstChild("node_modules")
        and game:GetService("ReplicatedStorage").rbxts_include.node_modules:FindFirstChild("@rbxts")
        and game:GetService("ReplicatedStorage").rbxts_include.node_modules["@rbxts"]:FindFirstChild("net")
        and game:GetService("ReplicatedStorage").rbxts_include.node_modules["@rbxts"].net:FindFirstChild("out")
        and game:GetService("ReplicatedStorage").rbxts_include.node_modules["@rbxts"].net.out:FindFirstChild("_NetManaged")
    return path
end

local NetManaged = getNetManaged()
local Remotes = {}
local RemoteNames = {}

if NetManaged then
    for _, child in ipairs(NetManaged:GetChildren()) do
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            table.insert(Remotes, child)
            table.insert(RemoteNames, child.Name)
        end
    end
end

if #RemoteNames == 0 then
    RemoteNames = {"No remotes found"}
end

-- ======== CREATE TAB ========
local tab = gui:tab{
    Icon = "rbxassetid://6034996695",
    Name = "Spammer"
}

-- ======== DROPDOWN ========
local SelectedRemote = nil
if #Remotes > 0 then
    SelectedRemote = Remotes[1]
end

local dropdown = tab:dropdown({
    Name = "Select Remote",
    Description = "Pick one remote to spam",
    StartingText = #Remotes > 0 and RemoteNames[1] or "None",
    Items = RemoteNames,
    Callback = function(v)
        for _, r in ipairs(Remotes) do
            if r.Name == v then
                SelectedRemote = r
                break
            end
        end
        gui:set_status("Selected: " .. (SelectedRemote and SelectedRemote.Name or "none"))
    end
})

-- ======== SPAM ALL TOGGLE ========
local spamAll = false
tab:toggle({
    Name = "Spam All",
    Description = "Spam every remote in the folder",
    Default = false,
    Callback = function(v)
        spamAll = v
        gui:set_status(spamAll and "Spamming ALL remotes" or "Spamming selected remote")
    end
})

-- ======== ENABLE SPAM TOGGLE ========
getgenv().SpamEnabled = false
tab:toggle({
    Name = "Enable Spam",
    Description = "Start/stop spamming",
    Default = false,
    Callback = function(v)
        getgenv().SpamEnabled = v
        gui:set_status(v and "SPAMMING" or "Idle")
    end
})

-- ======== REFRESH BUTTON ========
tab:button({
    Name = "⟳ Refresh",
    Callback = function()
        NetManaged = getNetManaged()
        if NetManaged then
            Remotes = {}
            RemoteNames = {}
            for _, child in ipairs(NetManaged:GetChildren()) do
                if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                    table.insert(Remotes, child)
                    table.insert(RemoteNames, child.Name)
                end
            end
            if #RemoteNames == 0 then
                RemoteNames = {"No remotes found"}
            end
            -- Update dropdown
            dropdown:Refresh(RemoteNames)
            if #Remotes > 0 then
                SelectedRemote = Remotes[1]
            else
                SelectedRemote = nil
            end
            gui:set_status("Refreshed: " .. #Remotes .. " remotes")
        else
            gui:set_status("_NetManaged not found!")
        end
    end
})

-- ======== STATUS DISPLAY (using a button as status) ========
-- Mercury doesn't have a label, so we'll use a button
local statusBtn = tab:button({
    Name = "Status: Idle",
    Callback = function() end -- no action
})

-- Update status button text
local function updateStatus(text)
    statusBtn:Set(text)
end

-- Override gui:set_status to also update the button
local originalSetStatus = gui.set_status
gui.set_status = function(self, text)
    originalSetStatus(self, text)
    statusBtn:Set("Status: " .. text)
end

-- ======== SPAM LOOP ========
local function spamLoop()
    while true do
        task.wait(0.01) -- adjust for speed
        if getgenv().SpamEnabled then
            if spamAll then
                -- Spam all remotes
                for _, r in ipairs(Remotes) do
                    if r:IsA("RemoteEvent") then
                        r:FireServer() -- no args
                    elseif r:IsA("RemoteFunction") then
                        r:InvokeServer() -- no args
                    end
                end
            else
                -- Spam only selected
                if SelectedRemote then
                    if SelectedRemote:IsA("RemoteEvent") then
                        SelectedRemote:FireServer()
                    elseif SelectedRemote:IsA("RemoteFunction") then
                        SelectedRemote:InvokeServer()
                    end
                end
            end
        end
    end
end

coroutine.wrap(spamLoop)()

-- ======== INITIAL STATUS ========
gui:set_status("Ready - " .. #Remotes .. " remotes found")
